#!/usr/bin/env sh
# Phase 44 / PRICE-08: fail the commit if any file in app/** or
# components/** contains a hard-coded EUR price (€ followed by >= 2 digits).
# Runs from prestigo/ git repo root, so paths are relative to prestigo/.

MATCHES=$(grep -rEl '€[0-9]{2,}' --include='*.ts' --include='*.tsx' app components 2>/dev/null \
  | grep -v 'app/compare/' \
  | grep -v 'app/guides/' \
  | grep -v 'app/blog/' \
  || true)

if [ -n "$MATCHES" ]; then
  echo "ERROR: Hard-coded EUR prices found in prestigo/app/** or prestigo/components/**."
  echo "Use DB-driven helpers (lib/route-prices.ts, lib/pricing-config.ts, lib/airport-promo.ts) instead."
  echo ""
  echo "Matched files:"
  echo "$MATCHES"
  exit 1
fi

exit 0
