# ── Google Maps ────────────────────────────────────────────────────────────────

# Client-side Places Autocomplete key — restricted to Places API + HTTP referrer
# Source: Google Cloud Console > APIs & Services > Credentials > your client key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_KEY_HERE

# Server-side Routes API key — API restriction only, NO HTTP referrer restriction
# Source: Google Cloud Console > APIs & Services > Credentials > your server key
GOOGLE_MAPS_API_KEY=YOUR_KEY_HERE

# Feature flag: switch booking-form autocomplete to Places API (New).
# The legacy `use-places-autocomplete` library hits the deprecated
# AutocompleteService (legacy status since 2025-03-01). When set to "1",
# BookingWidget swaps to AddressInputNew which calls
# places.googleapis.com/v1/places:autocomplete via places-autocomplete-hook.
# REQUIRES "Places API (New)" enabled in Google Cloud Console
# (it is a separate API from legacy "Places API").
# Leave unset or "0" to keep the legacy implementation.
NEXT_PUBLIC_USE_NEW_PLACES_API=0

# ── Supabase ──────────────────────────────────────────────────────────────────

# Supabase project URL
# Source: Supabase Dashboard > Project Settings > API > Project URL
SUPABASE_URL=https://your-project.supabase.co

# Service role key — server-side only, never expose to browser
# Source: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=YOUR_KEY_HERE

# Supabase anon/public key — safe for browser, used by @supabase/ssr client
# Source: Supabase Dashboard > Project Settings > API > anon public key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key — NOT service_role. This key is safe for browser exposure.
# Source: Supabase Dashboard > Project Settings > API > anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ── Stripe ────────────────────────────────────────────────────────────────────

# Stripe live secret key
# Source: Stripe Dashboard > Developers > API keys > Secret key (live mode)
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE

# Stripe webhook signing secret — set in Phase 8 after registering live Stripe webhook
# Source: Stripe Dashboard > Developers > Webhooks > your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# ── Resend ────────────────────────────────────────────────────────────────────

# Resend API key for transactional email
# Source: Resend Dashboard > API Keys > Create API Key
RESEND_API_KEY=re_YOUR_KEY_HERE

# ── Health check ──────────────────────────────────────────────────────────────

# Secret token for /api/health — pass as "Authorization: Bearer <value>"
# Generate: openssl rand -hex 32
HEALTH_SECRET=YOUR_SECRET_HERE

# ── Upstash Redis (distributed rate limiting) ─────────────────────────────────
# Required in production to share rate-limit state across all serverless instances.
# Without these, the app falls back to an in-memory limiter (fine for local dev).
# Source: Upstash Console > your database > REST API tab
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN_HERE

# ── Application ───────────────────────────────────────────────────────────────

# Public site URL — used for CSRF origin validation on admin API routes.
# Must match the exact origin (scheme + host, no trailing slash).
# Source: your Vercel deployment URL or custom domain
NEXT_PUBLIC_SITE_URL=https://rideprestigo.com

# Manager email address for booking alert notifications
# Source: your own email address
MANAGER_EMAIL=manager@rideprestige.com
